{
  "name": "@articket/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "echo 'lint pendiente'",
    "test": "vitest run",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "reservation:cleaner": "tsx src/jobs/releaseExpiredReservations.ts",
    "worker:notifications": "tsx src/workers/notificationsWorker.ts",
    "start:worker": "node dist/workers/notificationsWorker.js"
  },
  "dependencies": {
    "@articket/shared": "workspace:*",
    "@fastify/cors": "8.5.0",
    "@fastify/jwt": "8.0.1",
    "@fastify/sensible": "5.6.0",
    "@prisma/client": "5.22.0",
    "@sendgrid/mail": "8.1.4",
    "bcryptjs": "2.4.3",
    "bullmq": "5.12.11",
    "dotenv": "16.4.5",
    "fastify": "4.28.1",
    "ioredis": "5.4.1",
    "nanoid": "5.0.8",
    "pino": "9.4.0",
    "prisma": "5.22.0",
    "prom-client": "15.1.3",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "22.10.2",
    "tsx": "4.19.1",
    "typescript": "5.6.2",
    "vitest": "2.1.1"
  }
}
