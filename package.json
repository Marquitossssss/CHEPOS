{
  "name": "articket",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "format": "pnpm -r format",
    "db:migrate": "pnpm --filter @articket/api db:migrate",
    "db:seed": "pnpm --filter @articket/api db:seed"
  }
}
