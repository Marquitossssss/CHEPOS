{
  "name": "articket-platform",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "start": "./scripts/start.sh",
    "test": "./scripts/test.sh",
    "verify": "./scripts/verify.sh",
    "lint": "./scripts/lint.sh",
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "format": "pnpm -r format",
    "db:migrate": "pnpm --filter @articket/api db:migrate",
    "db:seed": "pnpm --filter @articket/api db:seed",
    "smoke": "./scripts/runtime-smoke.sh"
  }
}
